  "environment": "*",
  "entrypoints": {
    "main": [
      "mod.fuji.Fuji"
    ]
  },
  "accessWidener": "fuji.accesswidener",
  "mixins": [
    "fuji.mixins.json"
  ],
  "depends": {
    "fabricloader": "*",
    "minecraft": $compatible_minecraft_versions,
    "java": ">=${java_version}"
  },
  "suggests": {
    "luckperms": "*",
    "spark": "*"
  },
  "custom": {
    "mc-publish": {
      "dependencies": $mc_publish_dependencies_list
    }
  }
}
